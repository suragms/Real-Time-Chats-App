# ===========================================
# Environment variables for Real-Time Chat App
# Copy to .env.local for local dev, or add to Vercel/Netlify for hosting.
# ===========================================

# --- Required (InsForge) ---
# Backend URL from InsForge project dashboard
NEXT_PUBLIC_INSFORGE_BASE_URL=https://x9n7dmd8.us-east.insforge.app
# Project API / anon key (from InsForge dashboard; keep this secret in .env.local only)
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key

# --- Optional ---
# Storage bucket for chat image/file attachments (default: chat-attachments)
# NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET=chat-attachments

# Admin API key (only for local scripts: create-realtime-channels, etc.)
# INSFORGE_API_KEY=your-admin-api-key
